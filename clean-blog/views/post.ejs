<%- include("./partials/_header.ejs") -%>


<body>

  <%- include("./partials/_navigation.ejs") -%>

  <!-- Page Header -->
  <header class="masthead" style="background-image: url('img/post-bg.jpg')">
    <div class="overlay"></div>
    <div class="container">
      <div class="row">
        <div class="col-lg-8 col-md-10 mx-auto">
          <div class="post-heading">
            <h1><%= post.name %></h1>
            <h2 class="subheading"><%= post.message %></h2>
            <span class="meta">Posted by
              <a href="#">Start Bootstrap</a>
               Son güncelleme: <%= post.updatedAt.toLocaleString("tr-TR") %></span>
          </div>
         
        </div>
      </div>
    </div>
  </header>

  <!-- Post Content -->
  <article>
    <div class="container">
      <div class="row">
        <div class="col-lg-8 col-md-10 mx-auto">
          <h2><%= post.name %></h2>
          <p><%= post.message %></p>
          <p>Son güncelleme: <small> <%= post.updatedAt.toLocaleString("tr-TR") %></small></p>
           <div>
            <a href="/posts/edit/<%= post._id %>" class="btn btn-info">Update</a>
            <a href="" class="btn btn-danger ">Delete</a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <hr>

<%- include("./partials/_footer.ejs") -%>


  <!-- Bootstrap core JavaScript -->
  <script src="vendor/jquery/jquery.min.js"></script>
  <script src="vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

  <!-- Custom scripts for this template -->
  <script src="js/clean-blog.min.js"></script>

</body>

</html>
